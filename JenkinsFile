pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                sh 'mvn package'
            }
        }
        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }
        stage('Deploy') {
            steps {
                sh 'mvn deploy'
            }
        }
    }

    post {
        failure {
            mail to: 'devops@agentic.ai',
                    subject: 'Jenkins Job Failure',
                    body: 'Jenkins job failed, please check the console output for more information.'
        }
    }
}
